<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">
    <nav class="bg-white shadow px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
            <h1 class="text-xl font-bold">🌸 Admin Dashboard</h1>
            <div class="flex items-center gap-2 ml-6">
                <img src="<%= user.avatar %>" alt="avatar" class="w-8 h-8 rounded-full">
                <span class="font-medium"><%= user.chosen_username || user.username %></span>
            </div>
        </div>
        <div class="flex gap-2">
            <a href="/" class="text-blue-600 hover:underline">Home</a>
            <a href="/admin/tester" class="bg-green-600 text-white px-3 py-1 rounded hover:bg-green-700">Webhook Tester</a>
            <a href="/logout" class="bg-red-500 text-white px-3 py-1 rounded hover:bg-red-600">Logout</a>
        </div>
    </nav>

    <main class="max-w-6xl mx-auto p-6">
        <h2 class="text-2xl font-bold mb-4">Overview</h2>
        <div class="bg-white rounded-lg shadow p-6 mb-6">
            <p class="text-lg">Total Webhook Keys: <span class="font-bold text-2xl"><%= totalKeys %></span></p>
        </div>

        <h2 class="text-2xl font-bold mb-4">All Webhook Keys</h2>
        <div class="bg-white rounded-lg shadow overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Key</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">User</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Created</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    <% keys.forEach(key => { %>
                        <tr>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-mono"><%= key.key %></td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm"><%= key.chosen_username || key.username %></td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm"><%= key.email %></td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm"><%= key.created_at %></td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                <a href="/admin/view/<%= key.key %>" class="text-blue-600 hover:text-blue-800">View Logs</a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </main>
</body>
</html>
