<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Webhook Data - <%= key %></title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">
    <% if (locals.isAdminView) { %>
        <div class="bg-yellow-100 border-l-4 border-yellow-500 text-yellow-700 p-4 mb-4" role="alert">
            <p class="font-bold">Admin View</p>
            <p>You are viewing logs for a webhook key owned by another user.</p>
        </div>
    <% } %>

    <nav class="bg-white shadow p-4">
        <a href="<%= locals.isAdminView ? '/admin' : '/' %>" class="text-blue-600 hover:underline">
            ← Back to <%= locals.isAdminView ? 'Admin Dashboard' : 'Dashboard' %>
        </a>
    </nav>

    <main class="max-w-6xl mx-auto p-6">
        <div class="flex justify-between items-center mb-4">
            <h1 class="text-2xl font-bold">Webhook Key: <code class="bg-gray-200 p-1 rounded"><%= key %></code></h1>
            <div class="text-gray-600">
                Total requests: <span id="totalCount"><%= requests.length %></span>
                <span id="filteredCount" class="hidden">(<span></span> filtered)</span>
            </div>
        </div>

        <!-- Search Box -->
        <div class="mb-6">
            <input type="text" id="searchInput" placeholder="Search logs (method, headers, body, timestamp)..." 
                   class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>

        <% if (requests.length === 0) { %>
            <p class="bg-yellow-100 p-4 rounded">No requests received yet. Send a POST request to <code>/webhook/<%= key %></code>.</p>
        <% } else { %>
            <div id="requestsContainer" class="space-y-4">
                <% requests.forEach((req, index) => { %>
                    <div class="request-item bg-white rounded-lg shadow p-4" data-index="<%= index %>">
                        <div class="flex justify-between text-sm text-gray-500 mb-2">
                            <span class="method"><%= req.method %></span>
                            <span class="timestamp"><%= req.timestamp %></span>
                        </div>
                        <details>
                            <summary class="cursor-pointer text-blue-600">Headers</summary>
                            <pre class="headers bg-gray-100 p-2 mt-2 rounded text-xs overflow-auto"><% 
                                let headersObj = {};
                                try {
                                    if (req.headers) {
                                        headersObj = JSON.parse(req.headers);
                                    }
                                } catch (e) {
                                    headersObj = { error: 'Invalid JSON', raw: req.headers };
                                }
                                %><%= JSON.stringify(headersObj, null, 2) %></pre>
                        </details>
                        <div class="mt-2">
                            <p class="font-medium">Body:</p>
                            <pre class="body bg-gray-100 p-2 rounded text-xs overflow-auto"><%= req.body || '(empty)' %></pre>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const searchInput = document.getElementById('searchInput');
            const requestItems = document.querySelectorAll('.request-item');
            const totalCountSpan = document.getElementById('totalCount');
            const filteredCountSpan = document.getElementById('filteredCount');
            const filteredCountValue = filteredCountSpan.querySelector('span');

            // Store original content for each request item to search against
            const requestData = [];
            requestItems.forEach(item => {
                const method = item.querySelector('.method').textContent;
                const timestamp = item.querySelector('.timestamp').textContent;
                const headers = item.querySelector('.headers').textContent;
                const body = item.querySelector('.body').textContent;
                requestData.push({
                    element: item,
                    text: (method + ' ' + timestamp + ' ' + headers + ' ' + body).toLowerCase()
                });
            });

            function filterLogs() {
                const searchTerm = searchInput.value.toLowerCase().trim();
                let visibleCount = 0;

                requestData.forEach(item => {
                    if (searchTerm === '' || item.text.includes(searchTerm)) {
                        item.element.style.display = 'block';
                        visibleCount++;
                    } else {
                        item.element.style.display = 'none';
                    }
                });

                if (searchTerm !== '') {
                    filteredCountValue.textContent = visibleCount;
                    filteredCountSpan.classList.remove('hidden');
                } else {
                    filteredCountSpan.classList.add('hidden');
                }
            }

            searchInput.addEventListener('input', filterLogs);
        });
    </script>
</body>
</html>
