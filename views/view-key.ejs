<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Webhook Data - <%= key %></title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100">
    <nav class="bg-white shadow p-4">
        <a href="/" class="text-blue-600 hover:underline">← Back to Dashboard</a>
    </nav>
    <main class="max-w-6xl mx-auto p-6">
        <h1 class="text-2xl font-bold mb-2">Webhook Key: <code class="bg-gray-200 p-1 rounded"><%= key %></code></h1>
        <p class="mb-4 text-gray-600">Total requests: <%= requests.length %></p>

        <% if (requests.length === 0) { %>
            <p class="bg-yellow-100 p-4 rounded">No requests received yet. Send a POST request to <code>/webhook/<%= key %></code>.</p>
        <% } else { %>
            <div class="space-y-4">
                <% requests.forEach(req => { %>
                    <div class="bg-white rounded-lg shadow p-4">
                        <div class="flex justify-between text-sm text-gray-500 mb-2">
                            <span><%= req.method %></span>
                            <span><%= req.timestamp %></span>
                        </div>
                        <details>
                            <summary class="cursor-pointer text-blue-600">Headers</summary>
                            <pre class="bg-gray-100 p-2 mt-2 rounded text-xs overflow-auto"><%= JSON.stringify(JSON.parse(req.headers), null, 2) %></pre>
                        </details>
                        <div class="mt-2">
                            <p class="font-medium">Body:</p>
                            <pre class="bg-gray-100 p-2 rounded text-xs overflow-auto"><%= req.body %></pre>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </main>
</body>
</html>
