<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pink Webhook Generator</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen">
    <!-- Navbar: title + user on left, logout on right -->
    <nav class="bg-white shadow px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
            <h1 class="text-xl font-bold">🌸 Pink Webhook Generator</h1>
            <% if (user) { %>
                <div class="flex items-center gap-2 ml-6">
                    <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" 
                         alt="avatar" 
                         class="w-8 h-8 rounded-full"
                         onerror="this.src='https://cdn.discordapp.com/embed/avatars/0.png'">
                    <span class="font-medium"><%= user.username %></span>
                </div>
            <% } %>
        </div>
        <% if (user) { %>
            <a href="/logout" class="bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600 text-sm">Logout</a>
        <% } %>
    </nav>

    <main class="max-w-4xl mx-auto p-6">
        <% if (user) { %>
            <!-- Logged‑in dashboard -->
            <div class="bg-white rounded-lg shadow p-6 mb-6">
                <h2 class="text-2xl font-semibold mb-4">Generate a new webhook URL</h2>
                <button id="generateBtn" class="bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 transition">
                    + Generate New
                </button>
                <div id="newUrlContainer" class="mt-4 hidden">
                    <p class="text-lg font-medium">Your new webhook URL:</p>
                    <div class="flex items-center gap-2 mt-2">
                        <input id="webhookUrlInput" type="text" readonly class="flex-1 bg-gray-100 p-3 rounded border" />
                        <button id="copyBtn" class="bg-blue-600 text-white px-4 py-3 rounded hover:bg-blue-700">
                            Copy
                        </button>
                    </div>
                    <p class="mt-2 text-gray-600">
                        Use this URL in your scripts. <br>
                        <a id="viewLink" href="#" target="_blank" class="text-blue-600 underline">View received data</a>
                    </p>
                </div>
            </div>

            <div class="bg-white rounded-lg shadow p-6">
                <h2 class="text-2xl font-semibold mb-4">Your Webhook Keys</h2>
                <% if (keys.length === 0) { %>
                    <p class="text-gray-500">No webhook keys generated yet.</p>
                <% } else { %>
                    <ul class="divide-y">
                        <% keys.forEach(key => { %>
                            <li class="py-4">
                                <div class="flex items-center justify-between">
                                    <div class="flex-1">
                                        <code class="text-sm bg-gray-100 p-2 rounded block break-all"><%= key.key %></code>
                                        <span class="text-xs text-gray-500">Created: <%= key.created_at %></span>
                                    </div>
                                    <div class="flex gap-2 ml-4">
                                        <button class="copyKeyBtn text-blue-600 hover:text-blue-800" data-key="<%= key.key %>">Copy URL</button>
                                        <a href="/view/<%= key.key %>" class="text-green-600 hover:text-green-800">View Data</a>
                                    </div>
                                </div>
                            </li>
                        <% }) %>
                    </ul>
                <% } %>
            </div>
        <% } else { %>
            <!-- Centered sign‑in for logged‑out users (larger) -->
            <div class="min-h-[70vh] flex items-center justify-center">
                <div class="bg-white rounded-lg shadow-xl p-16 text-center max-w-2xl">
                    <h2 class="text-4xl font-bold mb-6">🌸 Pink Webhook Generator</h2>
                    <p class="text-gray-600 text-xl mb-10">Sign in with Discord to create your private webhook endpoints.</p>
                    <a 
                        href="https://discord.com/oauth2/authorize?client_id=1479619071828955337&response_type=code&redirect_uri=https%3A%2F%2Fwebhooks-gwsp.onrender.com%2Fauth%2Fdiscord%2Fcallback&scope=identify%20email%20guilds" 
                        class="bg-indigo-600 text-white px-10 py-5 rounded-lg text-2xl hover:bg-indigo-700 inline-flex items-center gap-4"
                    >
                        <img src="https://cdn.jsdelivr.net/npm/simple-icons@v5/icons/discord.svg" class="w-8 h-8 filter invert" alt="">
                        Sign in with Discord
                    </a>
                </div>
            </div>
        <% } %>
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const generateBtn = document.getElementById('generateBtn');
            const newUrlContainer = document.getElementById('newUrlContainer');
            const webhookUrlInput = document.getElementById('webhookUrlInput');
            const viewLink = document.getElementById('viewLink');
            const copyBtn = document.getElementById('copyBtn');

            if (generateBtn) {
                generateBtn.addEventListener('click', async () => {
                    const res = await fetch('/generate', { method: 'POST' });
                    const data = await res.json();
                    const base = window.location.origin;
                    const fullUrl = base + data.webhookUrl;
                    webhookUrlInput.value = fullUrl;
                    viewLink.href = base + data.viewUrl;
                    newUrlContainer.classList.remove('hidden');
                });
            }

            if (copyBtn) {
                copyBtn.addEventListener('click', () => {
                    webhookUrlInput.select();
                    navigator.clipboard.writeText(webhookUrlInput.value).then(() => {
                        alert('Copied to clipboard!');
                    });
                });
            }

            document.querySelectorAll('.copyKeyBtn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const key = btn.dataset.key;
                    const url = window.location.origin + '/webhook/' + key;
                    navigator.clipboard.writeText(url).then(() => {
                        alert('Copied webhook URL!');
                    });
                });
            });
        });
    </script>
</body>
</html>
